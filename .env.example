# ============================================================
# RustDesk Server（社群版）環境變數
# 本檔案包含敏感資訊，已加入 .gitignore，切勿 commit。
# ============================================================

# ── 部署域名 ──
# ID/Relay Server 直連域名（DNS A 記錄指向主機公網 IP）
RUSTDESK_DOMAIN=rustdesk-server.example.com

# API Server URL（走 Cloudflare Tunnel 的完整 HTTPS URL）
RUSTDESK_API_SERVER=https://rustdesk-console.example.com

# ── Cloudflare Tunnel ──
# 從 Cloudflare Zero Trust Dashboard → Networks → Tunnels 建立後取得
CLOUDFLARE_TUNNEL_TOKEN=<替換為你的 Tunnel Token>

# ── JWT 金鑰 ──
# 用於 API Token 簽發驗證，設定一組隨機字串（建議 128+ 字元）
# 若未使用 MUST_LOGIN，可留空以停用 JWT 驗證
# 產生隨機金鑰: openssl rand -base64 256
RUSTDESK_API_JWT_KEY=<替換為一組隨機字串>

# ── 強制登入 ──
# Y = 客戶端必須登入 API 帳號才能發起遠端連線
# N = 不強制
MUST_LOGIN=Y

# ── 註冊 ──
# true = 允許使用者自行註冊帳號
# false = 僅管理員可建立帳號（預設）
RUSTDESK_API_APP_REGISTER=false

# ── 後台外觀自訂 ──
# 瀏覽器首頁與後台主標題
RUSTDESK_API_ADMIN_TITLE=實驗室遠端連線管理中心

# 後台歡迎介面（支援 HTML，使用行內 inline CSS 樣式確保美觀）
# 🚨 請維持在單行字串中
RUSTDESK_API_ADMIN_HELLO="<div style='max-width: 650px; margin: 0 auto; background: linear-gradient(135deg, #f0f4ff 0%, #e6ecf8 100%); padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-family: sans-serif;'><h2 style='color: #1a365d; text-align: center; border-bottom: 2px solid #c3d4f2; padding-bottom: 15px; margin-bottom: 20px; font-weight: bold;'>🚀 歡迎使用實驗室 <b>RustDesk</b> 管理後台</h2><p style='text-align: center; font-size: 15px; color: #4a5568; line-height: 1.6;'>本系統受 🛡️ Cloudflare Zero Trust 安全隧道端對端加密保護。<br>若需連線授權、配發位址簿或客戶端配置，請聯繫 <b>IT 管理員</b>。</p><div style='background: white; padding: 20px; border-radius: 8px; margin-top: 25px; border-left: 5px solid #4299e1;'><ul style='color: #2d3748; font-size: 14px; line-height: 1.8; margin: 0; padding-left: 20px;'><li style='margin-bottom: 10px;'>🔒 <b>安全守則</b>：嚴禁跨組共用帳號，初次登入請立即修改高強度密碼。</li><li style='margin-bottom: 10px;'>📊 <b>設備維運</b>：管理員可在此介面審核帳號、派發群組配置與稽核連線日誌。</li><li>⛔ <b>異常防護</b>：連續錯誤登入將觸發 IP 封鎖，如遇鎖定請回報 IT 管理員解鎖。</li></ul></div></div>"